{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@matsugov/tsconfig/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"],
      "@components/*": ["./components/*"],
      "@hooks/*": ["./hooks/*"],
      "@lib/*": ["./lib/*"],
      "@app/*": ["./pages/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "./app/**/*.ts",
    "./app/**/*.tsx",
    "./components/**/*.tsx",
    "./components/**/*.ts",
    "./configs/**/*.ts",
    "./hooks/**/*.ts",
    "./utils/**/*.ts",
    ".next/types/**/*.ts",
    "./global.d.ts",
    "middleware.ts",
    "app/[slug]/route.ts",
    "middleware/handlers/cmsRedirects.ts",
    "app/assembly-districts/[[...slug]]",
    "app/boards/[slug]/directory/page.tsx"
  ],
  "exclude": ["node_modules"]
}
