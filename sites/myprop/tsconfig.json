{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@matsugov/tsconfig/nextjs.json",
  "compilerOptions": {
    "target": "ES2017",
    "strict": false,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./*"],
      "@components/*": ["./components/*"],
      "@utils/*": ["./utils/*"],
      "@app/*": ["./app/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
