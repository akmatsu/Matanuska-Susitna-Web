{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@matsugov/tsconfig/nextjs.json",
  "compilerOptions": {
    "target": "ES2017",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "tailwind.config.js"
  ],
  "exclude": ["node_modules"]
}
