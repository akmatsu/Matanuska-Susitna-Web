{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@matsugov/tsconfig/library.json",
  "compilerOptions": {
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "src/**/*.stories.ts", "src/**/*.stories.tsx"]
}
